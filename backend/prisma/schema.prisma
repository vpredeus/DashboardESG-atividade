generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Desafios {
  id                          Int       @id @default(autoincrement())
  postado                     DateTime? @db.Timestamp(6)
  tipo                        String?
  empresa                     String?
  responsavel                 String?
  email                       String?
  titulo_desafio              String?
  descricao_desafio           String?
  descricao                   String?
  area_primaria               String?
  area_secundaria             String?
  resumo                      String?
  ods_1                       Int?
  ods_2                       Int?
  ods_3                       Int?
  impacto_social_direto_num   Int?
  impacto_social_indireto_num Int?
  eixo                        String?
  natureza                    String?
}

model usuarios {
  id        Int       @id @default(autoincrement())
  nome      String
  sobrenome String
  email     String    @unique
  senha     String
  role      String?   @default("user")
  criado_em DateTime? @default(now()) @db.Timestamp(6)
}
